{
  "asr": {
    "model_path": "src/third_party/sherpa-onnx/sense-voice-model"
  },
  "llm": {
    "host": "http://192.168.10.69:11434",
    "model": "qwen2.5:7b",
    "system_prompt": "你是小千，一个18岁的女大学生，性格活泼开朗。回答要生动有趣，像朋友聊天一样自然，50字左右。不要称呼用户为小千，不要在回复中重复自己的名字。只使用中文回答，不要用日语或任何其他语言。当前时间: {time}。"
  },
  "tts": {
    "rate": 200,
    "voice": "cmn+f3",
    "backend": "piper",
    "piper_model": "~/pretrained_models/piper/zh_CN/zh_CN-huayan-medium.onnx"
  },
  "wake_word": {
    "keyword": ""
  },
  "speaker_verification": {
    "enroll_dir": "speaker_voice",
    "threshold": 0.35
  },
  "audio": {
    "sample_rate": 16000
  },
  "vad": {
    "backend": "adaptive",
    "energy_threshold": 0.003,
    "min_speech_frames": 8,
    "min_silence_frames": 20,
    "pre_speech_frames": 15,
    "adaptive_factor": 3.0,
    "min_energy": 0.006,
    "cooldown_frames": 25
  },
  "interactive": {
    "barge_in_enabled": false,
    "barge_in_energy_ratio": 2.0,
    "max_response_chars": 60
  },
  "memory": {
    "max_rounds": 10,
    "max_tokens": 2048,
    "persist_dir": "data/memory",
    "long_term_enabled": true,
    "auto_extract": true
  },
  "function_calling": {
    "enabled": true,
    "model": ""
  },
  "react": {
    "enabled": true,
    "max_steps": 2
  },
  "reflection": {
    "enabled": false,
    "model": "qwen2.5:0.5b"
  },
  "multi_agent": {
    "enabled": false,
    "critic_model": "qwen2.5:0.5b",
    "max_rounds": 1
  },
  "streaming_asr": {
    "enabled": true,
    "backend": "chunked",
    "model": "",
    "min_chunk": 0.8,
    "chunk_intv": 0.5
  },
  "embedding": {
    "backend": "onnx",
    "model_dir": "models/embedding"
  },
  "skills": {
    "weather": { "enabled": true },
    "time": { "enabled": true },
    "web_search": { "enabled": false },
    "rag": { "enabled": true, "docs_dir": "knowledge_base" }
  }
